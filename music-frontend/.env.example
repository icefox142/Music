# Mock 数据开关
# true: 使用本地 mock 数据（开发测试用）
# false: 使用真实 API
VITE_USE_MOCK=false

# API 基础 URL
# 本地开发: http://localhost:9999
# 生产环境: https://api.example.com
VITE_API_BASE_URL=http://localhost:9999

# 对象存储/CDN 基础 URL
# 本地开发: 留空（图片在前端 public/emojis/ 目录，使用前端服务器）
# 生产环境: 设置为 CDN 地址（如 https://cdn.example.com）
#
# 示例：
# - 本地开发: VITE_OSS_URL=
# - 生产环境: VITE_OSS_URL=https://cdn.example.com
VITE_OSS_URL=

# 测试 JWT Token（仅用于开发，从 API测试指南.md 获取）
# 实际使用时应该通过登录接口获取
VITE_TEST_TOKEN=
